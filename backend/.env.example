# ── PostgreSQL (project data + media review rules) ──────────────── [REQUIRED]
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Notion (only needed for migration: /api/migrate-from-notion) ───────────────
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── AI providers ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
QWEN_IMAGE_EDIT_URL=your_qwen_endpoint_here

# ── Supabase (images only) ─────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here   # service role key — keep secret, backend only
